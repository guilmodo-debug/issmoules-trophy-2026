  grid.innerHTML = sorted.map(([item, count]) => `
    <div class="pred-card">
      <div class="pred-flag">${countryFlags[item]||'⚽'}</div>
      <div class="pred-country">${item}</div>
      <div class="pred-bar-wrap"><div class="pred-bar" style="width:${Math.round(count/max*100)}%"></div></div>
