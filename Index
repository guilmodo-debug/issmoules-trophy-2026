<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Issmoules Trophy 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:#0a0f1e; --navy-mid:#0d1428; --navy-light:#141d35;
    --navy-card:rgba(10,15,30,0.92);
    --gold:#c9a84c; --gold-light:#e8c87a; --gold-bright:#f5d78e; --gold-dark:#8a6a20;
    --red-star:#c0392b; --red-accent:#e74c3c;
    --white:#f0f2f8; --silver:#8899bb;
    --border:rgba(201,168,76,0.18); --border-light:rgba(201,168,76,0.08);
    --green-ok:#4caf7a; --orange-warn:#f0a030;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--navy);color:var(--white);font-family:'Barlow',sans-serif;min-height:100vh;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;background-image:repeating-linear-gradient(-45deg,transparent,transparent 40px,rgba(201,168,76,0.02) 40px,rgba(201,168,76,0.02) 41px);pointer-events:none;z-index:0;}
  body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 70% 40% at 50% 0%,rgba(201,168,76,0.07) 0%,transparent 60%);pointer-events:none;z-index:0;}
  .app{position:relative;z-index:1;}

  /* ===== HEADER ===== */
  header{background:linear-gradient(180deg,rgba(8,12,24,0.99),rgba(12,18,36,0.98));border-bottom:1px solid var(--border);padding:0 2rem;position:sticky;top:0;z-index:100;box-shadow:0 4px 40px rgba(0,0,0,0.6);}
  .header-inner{max-width:1400px;margin:0 auto;height:68px;display:flex;align-items:center;justify-content:space-between;gap:1rem;}

  .logo{display:flex;align-items:center;gap:0.75rem;flex-shrink:0;}
  .logo-emblem{width:44px;height:44px;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(201,168,76,0.4));}
  .logo-text h1{font-family:'Bebas Neue',sans-serif;font-size:1.45rem;letter-spacing:3px;background:linear-gradient(135deg,var(--gold-bright),var(--gold),var(--gold-dark));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
  .logo-text .subtitle{font-family:'Barlow Condensed',sans-serif;font-size:0.58rem;font-weight:700;letter-spacing:3px;color:var(--red-star);text-transform:uppercase;margin-top:1px;}

  /* COUNTDOWN — étiré */
  .countdown-block{display:flex;align-items:center;gap:0.75rem;background:rgba(201,168,76,0.06);border:1px solid rgba(201,168,76,0.22);border-radius:10px;padding:0.5rem 1.25rem;flex:1;max-width:380px;justify-content:center;}
  .countdown-label{font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--silver);white-space:nowrap;}
  .countdown-units{display:flex;gap:0.5rem;align-items:center;}
  .countdown-unit{text-align:center;min-width:38px;}
  .countdown-num{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;line-height:1;color:var(--gold-bright);display:block;letter-spacing:1px;}
  .countdown-sub{font-family:'Barlow Condensed',sans-serif;font-size:0.5rem;letter-spacing:1.5px;color:var(--silver);text-transform:uppercase;}
  .countdown-sep{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:var(--gold-dark);line-height:1;margin-bottom:6px;}

  /* RADIO BADGE */
  .radio-badge{position:relative;display:flex;align-items:center;gap:0.4rem;background:rgba(192,57,43,0.1);border:1px solid rgba(192,57,43,0.3);border-radius:8px;padding:0.45rem 0.9rem;cursor:pointer;transition:all 0.2s;font-family:'Barlow Condensed',sans-serif;font-size:0.82rem;font-weight:700;letter-spacing:1px;color:var(--white);flex-shrink:0;white-space:nowrap;}
  .radio-badge:hover{background:rgba(192,57,43,0.2);border-color:rgba(192,57,43,0.5);}
  .radio-notif{position:absolute;top:-4px;right:-4px;width:10px;height:10px;border-radius:50%;background:var(--red-accent);}
  .radio-notif::after{content:'';position:absolute;inset:0;border-radius:50%;background:var(--red-accent);animation:ripple 1.5s ease-out infinite;}
  @keyframes ripple{0%{transform:scale(1);opacity:1;}100%{transform:scale(2.5);opacity:0;}}

  .prize-pill{background:linear-gradient(135deg,var(--gold-dark),var(--gold),var(--gold-light));color:var(--navy);font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:0.85rem;letter-spacing:1px;padding:0.45rem 1.1rem;border-radius:20px;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;box-shadow:0 2px 16px rgba(201,168,76,0.35);white-space:nowrap;flex-shrink:0;}
  .prize-pill:hover{transform:translateY(-2px);box-shadow:0 4px 24px rgba(201,168,76,0.55);}

  /* TIMELINE BAR */
  .timeline-bar{background:rgba(8,12,24,0.95);border-bottom:1px solid var(--border-light);padding:0.55rem 2rem;}
  .timeline-inner{max-width:1400px;margin:0 auto;}
  .timeline-track{display:flex;align-items:center;}
  .timeline-phase{flex:1;text-align:center;}
  .timeline-dot{width:10px;height:10px;border-radius:50%;margin:0 auto 3px;transition:all 0.2s;}
  .timeline-dot.done{background:var(--gold);box-shadow:0 0 6px rgba(201,168,76,0.5);}
  .timeline-dot.active{background:var(--red-accent);animation:pulseDot 1.5s ease-in-out infinite;}
  .timeline-dot.upcoming{background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.18);}
  @keyframes pulseDot{0%,100%{transform:scale(1);}50%{transform:scale(1.35);}}
  .timeline-label{font-family:'Barlow Condensed',sans-serif;font-size:0.58rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--silver);white-space:nowrap;}
  .timeline-label.active-label{color:var(--red-accent);}
  .timeline-label.done-label{color:var(--gold-dark);}
  .timeline-connector{height:1px;background:var(--border-light);flex:1;max-width:28px;}
  .timeline-connector.done-conn{background:rgba(201,168,76,0.4);}

  .tagline-bar{background:linear-gradient(90deg,transparent,rgba(201,168,76,0.07),transparent);border-bottom:1px solid var(--border-light);text-align:center;padding:0.4rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:5px;color:var(--gold);text-transform:uppercase;}
  .comp-banner{background:rgba(10,15,30,0.8);border-bottom:1px solid var(--border-light);text-align:center;padding:0.4rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:2px;color:var(--silver);text-transform:uppercase;}
  .comp-banner span{color:var(--gold-light);font-weight:900;}

  /* LAYOUT */
  .main-layout{max-width:1400px;margin:0 auto;padding:2rem;display:grid;grid-template-columns:230px 1fr;gap:2rem;align-items:start;}

  /* SIDEBAR */
  aside{position:sticky;top:128px;display:flex;flex-direction:column;gap:0.25rem;}
  .nav-btn{display:flex;align-items:center;gap:0.75rem;padding:0.65rem 1rem;border-radius:6px;border:1px solid transparent;background:transparent;color:var(--silver);font-family:'Barlow Condensed',sans-serif;font-size:0.88rem;font-weight:600;letter-spacing:0.5px;cursor:pointer;transition:all 0.2s;text-align:left;width:100%;}
  .nav-btn:hover{background:rgba(201,168,76,0.06);color:var(--gold-light);border-color:var(--border);}
  .nav-btn.active{background:rgba(201,168,76,0.1);border-color:rgba(201,168,76,0.4);color:var(--gold-light);}
  .nav-icon{font-size:0.95rem;flex-shrink:0;}
  .nav-divider{height:1px;background:var(--border-light);margin:0.3rem 0;}

  .nav-btn.pulse-btn{animation:navPulse 2s ease-in-out infinite;}
  @keyframes navPulse{
    0%,100%{background:transparent;border-color:transparent;color:var(--silver);}
    50%{background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.5);color:var(--gold-bright);}
  }
  .nav-btn.pulse-btn.active{animation:none;background:rgba(201,168,76,0.1);border-color:rgba(201,168,76,0.4);color:var(--gold-light);}

  .admin-zone{background:rgba(201,168,76,0.04);border:1px dashed rgba(201,168,76,0.25);border-radius:8px;padding:1rem;margin-top:0.75rem;}
  .admin-zone h4{font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:0.6rem;}
  .admin-zone textarea{width:100%;min-height:70px;background:rgba(0,0,0,0.5);border:1px solid rgba(201,168,76,0.2);border-radius:5px;color:var(--white);font-family:'Barlow',sans-serif;font-size:0.7rem;padding:0.4rem;resize:vertical;margin-bottom:0.4rem;}
  .admin-zone textarea::placeholder{color:var(--silver);opacity:0.5;}
  .btn-import{width:100%;padding:0.45rem;background:linear-gradient(135deg,var(--gold-dark),var(--gold));color:var(--navy);border:none;border-radius:5px;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:0.75rem;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:opacity 0.2s;}
  .btn-import:hover{opacity:0.85;}

  /* MAIN */
  main{min-width:0;}
  .tab-content{display:none;animation:fadeIn 0.3s ease;}
  .tab-content.active{display:block;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
  .section-header{margin-bottom:1.5rem;}
  .section-header h2{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:4px;background:linear-gradient(135deg,var(--gold-bright),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
  .section-header p{color:var(--silver);font-size:0.83rem;margin-top:0.3rem;}
  .card{background:var(--navy-card);border:1px solid var(--border);border-radius:10px;overflow:hidden;backdrop-filter:blur(12px);box-shadow:0 4px 30px rgba(0,0,0,0.4),inset 0 1px 0 rgba(201,168,76,0.1);}

  /* TABLE */
  .table-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;min-width:500px;}
  thead tr{background:rgba(0,0,0,0.4);border-bottom:1px solid var(--border);}
  th{padding:0.85rem 1.25rem;font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold-dark);text-align:left;}
  th.center,td.center{text-align:center;}
  tbody tr{border-bottom:1px solid rgba(255,255,255,0.03);transition:background 0.15s;}
  tbody tr:hover{background:rgba(201,168,76,0.04);}
  td{padding:0.85rem 1.25rem;font-size:0.88rem;}

  /* CLASSEMENT */
  .rank-num{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;line-height:1;}
  .rank-1{color:var(--gold-bright);}.rank-2{color:#b8c8d8;}.rank-3{color:#cd7f32;}.rank-other{color:var(--silver);}
  .player-name{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;color:var(--white);}
  .prize-badge{display:inline-block;font-size:0.62rem;font-weight:900;font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;text-transform:uppercase;padding:0.18rem 0.45rem;border-radius:3px;margin-top:4px;margin-right:3px;}
  .badge-gold{background:rgba(201,168,76,0.15);color:var(--gold-light);border:1px solid rgba(201,168,76,0.4);}
  .badge-silver{background:rgba(184,200,216,0.12);color:#b8c8d8;border:1px solid rgba(184,200,216,0.3);}
  .badge-bronze{background:rgba(205,127,50,0.12);color:#cd7f32;border:1px solid rgba(205,127,50,0.3);}
  .pts{font-family:'Bebas Neue',sans-serif;font-size:1.55rem;color:var(--white);}
  .pronostics-count{font-size:0.78rem;color:var(--silver);font-family:'Barlow Condensed',sans-serif;}
  .exact-badge{display:inline-block;background:rgba(201,168,76,0.12);color:var(--gold-light);font-size:0.68rem;font-weight:700;padding:0.13rem 0.38rem;border-radius:3px;font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;}
  .section-row td{padding:0.35rem 1.25rem;font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;font-weight:900;letter-spacing:3px;text-transform:uppercase;}
  .section-podium td{background:rgba(201,168,76,0.07);color:var(--gold);border-top:1px solid rgba(201,168,76,0.25);}
  .section-chasse td{background:rgba(255,255,255,0.03);color:var(--silver);border-top:1px solid rgba(255,255,255,0.06);}
  .section-milieu td{background:rgba(255,255,255,0.02);color:rgba(136,153,187,0.6);border-top:1px solid rgba(255,255,255,0.04);}
  .section-fin td{background:rgba(192,57,43,0.04);color:rgba(192,57,43,0.6);border-top:1px solid rgba(192,57,43,0.1);}

  /* CLASSEMENT PLACEHOLDER */
  .classement-placeholder{background:rgba(201,168,76,0.04);border:1px solid rgba(201,168,76,0.15);border-radius:10px;padding:3rem 2rem;text-align:center;}
  .classement-placeholder .big-icon{font-size:3.5rem;margin-bottom:1rem;opacity:0.6;}
  .classement-placeholder h3{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:3px;color:var(--gold-light);margin-bottom:0.5rem;}
  .classement-placeholder p{color:var(--silver);font-size:0.85rem;}

  /* GROUPS */
  .groups-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(278px,1fr));gap:1rem;}
  .group-card{background:var(--navy-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;backdrop-filter:blur(12px);transition:border-color 0.2s;}
  .group-card:hover{border-color:rgba(201,168,76,0.35);}
  .group-header{background:linear-gradient(135deg,rgba(201,168,76,0.12),rgba(201,168,76,0.04));padding:0.6rem 1rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);}
  .group-letter{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:var(--gold-light);}
  .group-label{font-size:0.62rem;font-family:'Barlow Condensed',sans-serif;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--silver);}
  .team-row{display:flex;align-items:center;gap:0.75rem;padding:0.55rem 1rem;border-bottom:1px solid rgba(255,255,255,0.03);font-size:0.83rem;transition:background 0.15s;}
  .team-row:hover{background:rgba(201,168,76,0.04);}
  .team-row:last-child{border-bottom:none;}
  .team-flag{font-size:1.15rem;flex-shrink:0;}
  .team-name{font-family:'Barlow Condensed',sans-serif;font-weight:600;color:var(--white);flex:1;}
  .team-stats{display:flex;gap:0.5rem;font-size:0.68rem;font-family:'Barlow Condensed',sans-serif;color:var(--silver);}
  .team-stat{text-align:center;min-width:18px;}
  .team-stat.pts-stat{color:var(--gold-light);font-weight:700;}

  /* BRACKET */
  .bracket-note{background:rgba(201,168,76,0.06);border:1px solid rgba(201,168,76,0.2);border-radius:8px;padding:1rem 1.5rem;margin-bottom:1.5rem;font-family:'Barlow Condensed',sans-serif;font-size:0.88rem;letter-spacing:0.5px;color:var(--silver);}
  .bracket-note strong{color:var(--gold-light);}
  .phases-timeline{display:flex;flex-direction:column;gap:0.85rem;}
  .phase-block{background:var(--navy-card);border:1px solid var(--border);border-radius:8px;padding:1.1rem 1.5rem;display:flex;align-items:center;gap:1.5rem;transition:border-color 0.2s;}
  .phase-block:hover{border-color:rgba(201,168,76,0.3);}
  .phase-icon{font-size:1.8rem;flex-shrink:0;width:44px;text-align:center;}
  .phase-info h3{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;color:var(--white);letter-spacing:1px;}
  .phase-info p{font-size:0.78rem;color:var(--silver);margin-top:0.15rem;}
  .phase-date{margin-left:auto;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--gold);text-align:right;flex-shrink:0;}

  /* PRIZEPOOL */
  .prizepool-header{display:flex;align-items:center;justify-content:space-between;background:rgba(201,168,76,0.06);border:1px solid rgba(201,168,76,0.25);border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;}
  .prizepool-total{font-family:'Bebas Neue',sans-serif;font-size:3rem;line-height:1;background:linear-gradient(135deg,var(--gold-bright),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .prizepool-meta{font-family:'Barlow Condensed',sans-serif;font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--silver);margin-top:0.25rem;}
  .prizepool-note{font-size:0.75rem;color:var(--silver);text-align:right;max-width:240px;}
  .prize-section-title{font-family:'Barlow Condensed',sans-serif;font-size:0.68rem;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:var(--gold-dark);margin:1.25rem 0 0.75rem;}
  .prize-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:0.25rem;}
  .prize-card{background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem;text-align:center;position:relative;overflow:hidden;backdrop-filter:blur(12px);}
  .prize-card::before{content:'';position:absolute;top:0;right:0;width:60px;height:60px;border-radius:0 0 0 60px;opacity:0.12;}
  .prize-card.p1::before{background:var(--gold-bright);}.prize-card.p2::before{background:#b8c8d8;}.prize-card.p3::before{background:#cd7f32;}
  .prize-place{font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--silver);margin-bottom:0.4rem;}
  .prize-amount{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;line-height:1;}
  .prize-amount.gold{background:linear-gradient(135deg,var(--gold-bright),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .prize-amount.silver{color:#b8c8d8;}.prize-amount.bronze{color:#cd7f32;}
  .prize-pct{font-size:0.68rem;color:var(--silver);margin-top:0.2rem;font-family:'Barlow Condensed',sans-serif;}
  .bonus-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0.75rem;margin-bottom:1.5rem;}
  .bonus-card{background:var(--navy-card);border:1px solid var(--border-light);border-radius:8px;padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;}
  .bonus-name{font-family:'Barlow Condensed',sans-serif;font-size:0.85rem;font-weight:600;color:var(--white);}
  .bonus-pct{font-size:0.68rem;color:var(--silver);margin-top:2px;}
  .bonus-amount{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--red-accent);flex-shrink:0;}

  /* PARTICIPANTS TABLE — nouvel onglet */
  .participants-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;}
  .participants-header h3{font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--gold);}
  .counter-badges{display:flex;gap:0.5rem;}
  .counter-badge{font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:4px;letter-spacing:1px;}
  .cb-green{background:rgba(76,175,122,0.15);color:var(--green-ok);border:1px solid rgba(76,175,122,0.3);}
  .cb-orange{background:rgba(240,160,48,0.15);color:var(--orange-warn);border:1px solid rgba(240,160,48,0.3);}
  .cb-silver{background:rgba(136,153,187,0.12);color:var(--silver);border:1px solid rgba(136,153,187,0.2);}

  .participants-table{width:100%;border-collapse:collapse;}
  .participants-table th{padding:0.6rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold-dark);text-align:left;background:rgba(0,0,0,0.3);border-bottom:1px solid var(--border);}
  .participants-table td{padding:0.65rem 1rem;font-size:0.83rem;border-bottom:1px solid rgba(255,255,255,0.03);}
  .participants-table tr:hover td{background:rgba(201,168,76,0.03);}
  .p-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.95rem;color:var(--white);}
  .p-pseudo{font-size:0.72rem;color:var(--silver);font-style:italic;margin-top:2px;}

  .chip{display:inline-flex;align-items:center;gap:0.25rem;font-size:0.65rem;font-weight:700;font-family:'Barlow Condensed',sans-serif;letter-spacing:0.5px;padding:0.18rem 0.5rem;border-radius:4px;}
  .chip-ok{background:rgba(76,175,122,0.15);color:var(--green-ok);border:1px solid rgba(76,175,122,0.3);}
  .chip-pending{background:rgba(240,160,48,0.12);color:var(--orange-warn);border:1px solid rgba(240,160,48,0.25);}
